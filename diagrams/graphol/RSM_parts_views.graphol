        <iri>
          <value>https://cdm.ovh/rsm/partsAndViews/pavo</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/parts_views/pavi</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Parts and views</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/parts_views/pavi</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Adapter ontology aligning part-whole and view modeling patterns with DUL. It keeps one OWL-native authoritative containment pattern and adds a contextual containment-tree pattern for open-ended tree vocabularies.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/partsAndViews/pavo#AssetEntity</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/partsAndViews/pavo#AssetEntity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Asset entity</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/partsAndViews/pavo#AssetEntity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>any domain entity that can belong to the system being structured, whether atomic or composite at the chosen granularityany domain entity that can belong to the system being structured, whether atomic or composite at the chosen granularity</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/partsAndViews/pavo#ContainerEntity</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/partsAndViews/pavo#ContainerEntity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Container entity</lexicalForm>
                <datatype>http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral</datatype>
                <language/>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/partsAndViews/pavo#ContainerEntity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>an asset entity that may contain other asset entities.
Note: there are no limits to the containment recursion (no " leaf" or "terminal" objects are defined as such).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/partsAndViews/pavo#ContainmentSituation</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/partsAndViews/pavo#ContainmentSituation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Containment situation</lexicalForm>
                <datatype>http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral</datatype>
                <language/>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/partsAndViews/pavo#ContainmentSituation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Reified direct containment assertion scoped by a containment-tree individual. This pattern preserves tree identity and tree typing, but OWL 2 DL does not provide scoped transitive closure for a specific tree individual; use rules, SPARQL property paths, or materialization when per-tree closure is needed.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
