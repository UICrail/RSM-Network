        <iri>
          <value>https://cdm.ovh/rsm/network/netw</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw</subject>
              <property>http://purl.org/dc/elements/1.1/description</property>
              <object>
                <lexicalForm>Ontology for railway networks, their management, and their layout</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw</subject>
              <property>http://purl.org/dc/elements/1.1/title</property>
              <object>
                <lexicalForm>Railway network ontology</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw</subject>
              <property>http://purl.org/dc/elements/1.1/license</property>
              <object>
                <iri>https://creativecommons.org/licenses/by-sa/4.0/</iri>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw</subject>
              <property>http://purl.org/dc/elements/1.1/creator</property>
              <object>
                <lexicalForm>Airy Magnien</lexicalForm>
                <datatype/>
                <language/>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/network/netw#NetEntity</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#NetEntity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Net entity</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#NetEntity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Any entity (material or immaterial) in a network. "In a network" can result from ownership, functional relationships, legal definitions; such distinctions are not part of this ontology.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/network/netw#NetworkLayout</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#NetworkLayout</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Network layout</lexicalForm>
                <datatype>http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral</datatype>
                <language/>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#NetworkLayout</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Associates a Railway Network with a topology. Validity interval, if provided, bounds the validity of this association.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/network/netw#NetworkManagement</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#NetworkManagement</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Network management</lexicalForm>
                <datatype>http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral</datatype>
                <language/>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#NetworkManagement</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Relationship between a network and its infrastructure manager over a particular period of time (if provided).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/network/netw#NetworkTopology</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#NetworkTopology</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Network topology</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/network/netw#RailwayNetwork</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#RailwayNetwork</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Railway network</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#RailwayNetwork</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Denotes a railway network as understood by domain experts, including all material and immaterial aspects that constitute a network. The exact boundaries (ownership, functional relationship) are intentionally left open. The relationship between a network (as a container entity) and its contained assets are described in the Parts and Views (PAVO) ontology.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/network/netw#TopologyGraph</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#TopologyGraph</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Topology graph</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#TopologyGraph</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>A Topology Graph individual denotes an information object carrying a serialized graph, typically retrievable from an RDF file or a web document such as &lt;http://example.org/topology1>.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/network/netw#containsEntity</value>
          <irreflexive/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#containsEntity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>contains entity</lexicalForm>
                <datatype>http://www.w3.org/1999/02/22-rdf-syntax-ns#PlainLiteral</datatype>
                <language/>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#containsEntity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Refers to entities that are proper parts of the containing entity. 'Proper' entails that the property is irreflexive, and it is characterized as such in this version of the ontology. As container entities can contain other containers, use the transitive property closure to find all entities contained, directly or indirectly, in a container.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
