<?xml version="1.0"?>
<rdf:RDF xmlns="https://cdm.ovh/rsm/network/netw#"
     xml:base="https://cdm.ovh/rsm/network/netw"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:dul="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:netw="https://cdm.ovh/rsm/network/netw#"
     xmlns:pavo="https://cdm.ovh/rsm/partsAndViews/pavo#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:rsmt="https://cdm.ovh/rsm/time/time#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:stus="https://cdm.ovh/rsm/schemes/status#">
    <owl:Ontology rdf:about="https://cdm.ovh/rsm/network/netw">
        <owl:versionIRI rdf:resource="https://cdm.ovh/rsm/network/netw/0.1"/>
        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/partsAndViews/pavo"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/time/time"/>
        <dc:creator>Airy Magnien</dc:creator>
        <dc:description xml:lang="en">Ontology for railway networks, their management, and their layout</dc:description>
        <dc:license rdf:resource="https://creativecommons.org/licenses/by-sa/4.0/"/>
        <dc:title xml:lang="en">Railway network ontology</dc:title>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/license"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasSetting -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasSetting"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies"/>
    


    <!-- https://cdm.ovh/rsm/network/netw#containsEntity -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#containsEntity">
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/network/netw#isContainedIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">Refers to entities that are proper parts of the containing entity. &apos;Proper&apos; entails that the property is irreflexive, and it is characterized as such in this version of the ontology. As container entities can contain other containers, use the transitive property closure to find all entities contained, directly or indirectly, in a container.</rdfs:comment>
        <rdfs:label>contains entity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#hasLayout -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#hasLayout">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasSetting"/>
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/network/netw#isLayoutFor"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#RailwayNetwork"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkLayout"/>
        <rdfs:label xml:lang="en">has layout</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#hasSubNetwork -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#hasSubNetwork">
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/network/netw#isSubNetworkOf"/>
        <rdfs:comment xml:lang="en">Links an infrastructure artefact (network or sub-network) to its sub-networks.</rdfs:comment>
        <rdfs:label xml:lang="en">has sub network</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#isContainedIn -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#isContainedIn">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/network/netw#isContainedInTransitive"/>
        <rdfs:label xml:lang="en">is contained in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#isContainedInTransitive -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#isContainedInTransitive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:label>is contained in (transitive)</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#isLayoutFor -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#isLayoutFor">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkLayout"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#RailwayNetwork"/>
        <rdfs:label>is layout for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#isManagedBy -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#isManagedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasSetting"/>
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/network/netw#isManagementFor"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkManagement"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#RailwayNetwork"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#SocialAgent"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkManagement"/>
        <rdfs:comment xml:lang="en">refers to the management situation (at a moment in time)</rdfs:comment>
        <rdfs:label xml:lang="en">is managed by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#isManagementFor -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#isManagementFor">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#isSettingFor"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkManagement"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#RailwayNetwork"/>
        <rdfs:label xml:lang="en">is management for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#isSubNetworkOf -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#isSubNetworkOf">
        <rdfs:label>is subnetwork of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#satisfiesTopology -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#satisfiesTopology">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkLayout"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkTopology"/>
        <rdfs:comment xml:lang="en">a subproperty of dul:satisfies; links a situation to a description.</rdfs:comment>
        <rdfs:label xml:lang="en">satisfies topology</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#serializedAs -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#serializedAs">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkTopology"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#TopologyGraph"/>
        <rdfs:label xml:lang="en">serialized as</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#status -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#status">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkLayout"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Concept"/>
        <rdfs:comment xml:lang="en">concept (planned, actual...) to be borrowed from the scheme in status.ttl</rdfs:comment>
        <rdfs:label xml:lang="en">status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/time/time#hasValidityInterval -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/time/time#hasValidityInterval"/>
    


